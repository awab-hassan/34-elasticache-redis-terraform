# ======================================================================
# Portfolio .gitignore template — copy into each project repo as `.gitignore`
# ======================================================================
PROJECT_101.md
# ------ Secrets / credentials (NEVER commit) ----------------------------
*.pem
*.key
*.p12
*.pfx
*accessKeys*.csv
credentials
credentials.csv
.aws/
.env
.env.*
!.env.example
secrets.*
*.secret

# ------ Terraform -------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!example.tfvars
!terraform.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ------ CloudFormation / SAM -------------------------------------------
packaged-template.yaml
.aws-sam/

# ------ Node.js --------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/
package-lock.json.bak

# ------ Python ---------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ------ Build artefacts / archives -------------------------------------
dist/
build/
*.zip
*.rar
*.tar
*.tar.gz
*.7z

# ------ IDE / OS -------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------ Logs -----------------------------------------------------------
*.log
logs/

# ------ Database dumps (NEVER commit) ----------------------------------
*.sql
*.dump
*.bak
